# ─── KrishiConnect v2 — Environment Variables ────────────────────────────────
# Copy to .env and fill in. NEVER commit .env to GitHub.

# Supabase (https://supabase.com/dashboard/project/oielrikosffzuklajfpi/settings/api)
VITE_SUPABASE_URL=https://oielrikosffzuklajfpi.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# data.gov.in — Mandi prices (https://data.gov.in → Profile → API Key)
VITE_DATAGOV_API_KEY=your_datagov_key_here

# Fixer.io — optional; if omitted, GBP/INR uses open.er-api.com (no key).
VITE_FIXER_API_KEY=your_fixer_key_here

# UK Trade Tariff — No key needed, already live!

# ── SERVER-SIDE ONLY (set in Vercel Dashboard → Settings → Environment Variables) ──
# ANTHROPIC_API_KEY=sk-ant-...   ← DO NOT put this here with VITE_ prefix!
#                                   It would be exposed in the browser bundle.
#                                   Add it only in Vercel Dashboard.
